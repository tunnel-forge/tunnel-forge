# If logs say "Cannot detect this server's public IP", set VPN_PUBLIC_IP to the
# address VPN clients use to reach this machine (often your Wi-Fi LAN IP).
# This repo's docker-compose.yml uses network_mode: host (Linux) so IKE reaches
# Libreswan on that IP; update VPN_PUBLIC_IP when your LAN address changes.
VPN_PUBLIC_IP=192.168.1.104

VPN_IPSEC_PSK=your_ipsec_pre_shared_key
VPN_USER=your_vpn_username
VPN_PASSWORD=your_vpn_password
