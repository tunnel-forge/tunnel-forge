# Root local environment for Tunnel Forge.
# Keep this file shell-compatible and Docker Compose-friendly:
# - use KEY=VALUE
# - no spaces around =
# - quote only when the value itself needs shell quoting

# ------------------------------------------------------------------------------
# Local VPN server
# ------------------------------------------------------------------------------

# If logs say "Cannot detect this server's public IP", set VPN_PUBLIC_IP to the
# address VPN clients use to reach this machine, usually your Wi-Fi LAN IP.
VPN_PUBLIC_IP=192.168.1.104

VPN_IPSEC_PSK=your_ipsec_pre_shared_key
VPN_USER=your_vpn_username
VPN_PASSWORD=your_vpn_password

# ------------------------------------------------------------------------------
# Android release signing
# ------------------------------------------------------------------------------

# Choose exactly one keystore source:
# 1. Existing keystore file on disk
TUNNEL_FORGE_ANDROID_KEYSTORE_PATH=/absolute/path/to/upload-keystore.jks

# 2. Base64-encoded keystore content
TUNNEL_FORGE_ANDROID_KEYSTORE_BASE64=

TUNNEL_FORGE_ANDROID_KEYSTORE_PASSWORD=your_keystore_password
TUNNEL_FORGE_ANDROID_KEY_ALIAS=your_key_alias
TUNNEL_FORGE_ANDROID_KEY_PASSWORD=your_key_password
